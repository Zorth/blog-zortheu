---
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
		</div>
		<div class="social-links">
			<a href="https://www.tarragon.be/" target="_blank">
				<span class="sr-only">Tarragon</span>
				<img src="/icons/tarragon.svg" alt="" width="64" height="64" />
			</a>
			<a href="https://www.linkedin.com/in/jasper-goens/" target="_blank">
				<span class="sr-only">LinkedIn</span>
				<img src="/icons/linkedin.svg" alt="" width="32" height="32" />
			</a>
			<a href="https://github.com/Zorth" target="_blank">
				<span class="sr-only">GitHub</span>
				<img src="/icons/github.svg" alt="" width="32" height="32" />
			</a>
			<a href="mailto:jasper_goens@hotmail.com">
				<span class="sr-only">Email</span>
				<img src="/icons/email.svg" alt="" width="32" height="32" />
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: #0f1219;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 50%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.5rem;
		padding: 0.5rem 0;
	}
	nav a {
		padding: 0.5em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}
	.social-links a {
		display: flex;
		align-items: center;
		padding: 0.5em;
	}
	.social-links a:hover {
		opacity: 0.7;
	}
	.social-links img[src*="tarragon"] {
		width: 64px;
		height: 64px;
	}
	@media (max-width: 720px) {
		nav {
			justify-content: center;
			text-align: center;
		}
		h2 {
			width: 100%;
			margin-bottom: 0.5rem;
		}
		.social-links img[src*="tarragon"] {
			width: 48px;
			height: 48px;
		}
	}
</style>